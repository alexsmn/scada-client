{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja",
      "displayName": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "BUILD_NUMBER": "0",
        "OUTPUT_DIR": "build/${presetName}/bin",
        "CMAKE_MODULE_PATH": "${sourceDir};$env{THIRD_PARTY}/modus;$env{THIRD_PARTY}/qt/graph_qt;$env{THIRD_PARTY}/qt/schematic"
      }
    }
  ]
}
